{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathsvideo.dev/schemas/scene-types/number_line_operation.json",
  "title": "Scene: number_line_operation",
  "description": "Number line with animated jumps for addition/subtraction.",
  "type": "object",
  "required": ["range", "start_value", "jumps"],
  "additionalProperties": false,
  "properties": {
    "range": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
    "step": { "type": "number", "default": 1 },
    "start_value": { "type": "number" },
    "jumps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operation", "value"],
        "properties": {
          "operation": { "type": "string", "enum": ["add", "subtract"] },
          "value": { "type": "number" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
