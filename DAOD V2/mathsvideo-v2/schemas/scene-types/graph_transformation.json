{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathsvideo.dev/schemas/scene-types/graph_transformation.json",
  "title": "Scene: graph_transformation",
  "description": "Animated function transformations — stretch, shift, reflect.",
  "type": "object",
  "required": ["base_function", "transformations"],
  "additionalProperties": false,
  "properties": {
    "base_function": { "type": "string", "examples": ["x^2", "sin(x)"] },
    "transformations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["translate_x", "translate_y", "scale_x", "scale_y", "reflect_x", "reflect_y"] },
          "value": { "type": "number" },
          "narration_note": { "type": "string" }
        }
      }
    },
    "x_range": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
    "y_range": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
    "show_equation_update": { "type": "boolean", "default": true }
  }
}
