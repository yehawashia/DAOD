{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathsvideo.dev/schemas/scene-types/definition_card.json",
  "title": "Scene: definition_card",
  "description": "Formal definition with key terms highlighted.",
  "type": "object",
  "required": ["term", "definition"],
  "additionalProperties": false,
  "properties": {
    "term": { "type": "string" },
    "definition": { "type": "string" },
    "key_terms": { "type": "array", "items": { "type": "string" } },
    "example": { "type": "string" }
  }
}
