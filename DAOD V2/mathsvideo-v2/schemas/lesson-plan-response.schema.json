{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathsvideo.dev/schemas/lesson-plan-response.schema.json",
  "title": "Lesson Plan Response",
  "description": "Output from the lesson planner. Blueprint §19.2 and §5.4.",
  "type": "object",
  "required": ["lesson_title", "objective", "segments"],
  "additionalProperties": false,
  "properties": {
    "lesson_title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "objective": {
      "type": "string",
      "minLength": 10,
      "maxLength": 240,
      "description": "One-sentence learning objective."
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": { "$ref": "segment.schema.json" }
    },
    "branch_templates": {
      "type": "array",
      "description": "Pre-specified interruption branch templates. Lets the UI suggest follow-ups and lets the system pre-render likely branches.",
      "items": {
        "type": "object",
        "required": ["trigger_type", "example_question", "branch_scene_type", "branch_narration_template"],
        "additionalProperties": false,
        "properties": {
          "trigger_type": {
            "type": "string",
            "enum": ["step_justification", "concept_confusion", "example_request", "pace_adjustment"]
          },
          "example_question": { "type": "string", "minLength": 3 },
          "branch_scene_type": {
            "type": "string",
            "enum": [
              "equation_solve_steps", "equation_balance", "graph_function_plot", "graph_transformation",
              "geometry_construction", "geometry_proof", "number_line_operation", "fraction_visual",
              "table_reveal", "worked_example", "comparison_split", "definition_card",
              "recap_summary", "title_intro", "misconception_alert"
            ]
          },
          "branch_narration_template": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
