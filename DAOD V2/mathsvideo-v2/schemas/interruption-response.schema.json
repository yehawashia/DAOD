{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mathsvideo.dev/schemas/interruption-response.schema.json",
  "title": "Interruption Response",
  "description": "Response from the interruption engine containing the branch plan. Blueprint §19.4.",
  "type": "object",
  "required": ["interrupt_id", "branch_segments", "return_to_segment_id"],
  "additionalProperties": false,
  "properties": {
    "interrupt_id": { "type": "string", "minLength": 1 },
    "branch_segments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "description": "Blueprint caps at 3-4 branch segments.",
      "items": { "$ref": "segment.schema.json" }
    },
    "return_to_segment_id": {
      "type": "string",
      "minLength": 1,
      "description": "Segment to resume playback from after the branch completes."
    }
  }
}
